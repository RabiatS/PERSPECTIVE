# Example environment for spatial-viz-web — keep real keys OUT of git.
#
# Quick start:
#   1. Copy `.env.local.example` to `.env.local` in this folder.
#   2. Set `VITE_AI_PROVIDER` and keys (see below).
#   3. `npm run dev` in `web/`
#
# --- LLM token policy (opt-in; defaults save tokens) ---
# Heuristic LENS (no LLM) is the default. Enable LLM per feature:
#   VITE_AI_LENS_LLM=true           — LENS classification + reasoning (one call per upload)
#   VITE_AI_SCOUT_PIN_LLM=true     — SCOUT writes pin headlines/explanations (batched)
#   VITE_AI_CURATOR_LLM=true       — CURATOR adds LLM rationale on sub-scene spawn
# Disable anomaly pins entirely:
#   VITE_AI_SCOUT_ENABLED=false
#
# --- Where keys live ---
# A) Vite dev proxy: `OPENAI_API_KEY` / `ANTHROPIC_API_KEY` / `GEMINI_API_KEY` in `.env.local`
# B) Node gateway: run `../server` and set `VITE_AI_BACKEND_URL=http://localhost:8787` (no VITE_* keys)
# C) Static hosting: `VITE_*` keys (not recommended; keys in bundle)

VITE_AI_PROVIDER=openai
# options: openai | gemini | anthropic

# SCOUT: LLM-written pin copy (set true with a valid API key / proxy)
# VITE_AI_SCOUT_PIN_LLM=true

# Optional Isolation Forest (PRD SCOUT primary): POST JSON { features: number[][] }
# → { scores: number[] } same length as rows. Unset = client Z-score fallback only.
# VITE_SCOUT_API_URL=

# Optional AI gateway (see ../server/README.md)
# VITE_AI_BACKEND_URL=http://localhost:8787

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# VITE_OPENAI_API_KEY=
# VITE_ANTHROPIC_API_KEY=
# VITE_GEMINI_API_KEY=
# VITE_GOOGLE_API_KEY=

# VITE_OPENAI_MODEL=gpt-4o
# VITE_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# VITE_GEMINI_MODEL=gemini-1.5-flash

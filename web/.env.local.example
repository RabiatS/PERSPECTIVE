# Copy to `.env.local` in this folder. Never commit real secrets.
#
# --- Token policy (defaults minimize LLM use) ---
# LENS: heuristic only unless you set:
# VITE_AI_LENS_LLM=true
# SCOUT pin text: templates only unless:
# VITE_AI_SCOUT_PIN_LLM=true
# CURATOR rationale: PCA text only unless:
# VITE_AI_CURATOR_LLM=true
# Turn off all SCOUT work (no pins):
# VITE_AI_SCOUT_ENABLED=false
#
# --- Optional: Node gateway (keys on server only) ---
# Start: cd ../server && npm start
# VITE_AI_BACKEND_URL=http://localhost:8787

VITE_AI_PROVIDER=openai
# anthropic | openai | gemini

# SCOUT pin headlines/explanations via LLM (batched; uses API tokens)
VITE_AI_SCOUT_PIN_LLM=true

# Optional Isolation Forest API (PRD): POST { features } → { scores }; unset = Z-score fallback
# VITE_SCOUT_API_URL=

# --- Dev: server-side keys for Vite proxy (recommended; not bundled) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# --- Static build / no proxy (keys may end up in bundle) ---
# VITE_OPENAI_API_KEY=
# VITE_ANTHROPIC_API_KEY=
# VITE_GEMINI_API_KEY=
# VITE_GOOGLE_API_KEY=

# VITE_OPENAI_MODEL=gpt-4o
# VITE_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# VITE_GEMINI_MODEL=gemini-1.5-flash
